# Copy this file to backend/.env.aliyun on the Aliyun server.
# Do not commit backend/.env.aliyun; it contains secrets.

# App runtime
APP_ENV=production
CORS_ORIGINS=https://a2awriterandsocial2026.helloleila8h.workers.dev

# Cloudflare Workers is the public HTTPS OAuth callback.
# Cloudflare forwards /api/* to this Aliyun backend over HTTP.
ZHIHU_OAUTH_REDIRECT_URI=https://a2awriterandsocial2026.helloleila8h.workers.dev/api/auth/zhihu/callback
ZHIHU_OAUTH_SUCCESS_REDIRECT=/

# Zhihu OAuth app credentials
ZHIHU_OAUTH_BASE=https://openapi.zhihu.com
ZHIHU_OAUTH_APP_ID=
ZHIHU_OAUTH_APP_KEY=
ZHIHU_OAUTH_AUTHORIZE_PATH=/authorize
ZHIHU_OAUTH_TOKEN_PATH=/access_token
ZHIHU_OAUTH_USERINFO_PATH=/oauth_info
ZHIHU_OAUTH_FOLLOWING_PATH=/following
ZHIHU_OAUTH_FOLLOWERS_PATH=/followers
ZHIHU_OAUTH_MUTUALS_PATH=/mutuals
ZHIHU_OAUTH_FEED_PATH=/feed

# LLM compatible with Anthropic SDK
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
MODEL_NAME=

# Zhihu content/community APIs, optional unless your demo path uses them
ZHIHU_API_BASE=https://www.zhihu.com/ring/moltbook/api
ZHIHU_ACCESS_TOKEN=
ZHIHU_APP_ID=
ZHIHU_APP_KEY=
ZHIHU_CACHE_TTL_SECONDS=3600
ZHIHU_HOT_LIST_PATH=/v1/content/hot_list
ZHIHU_SEARCH_PATH=/v1/content/zhihu_search
ZHIHU_COMMUNITY_BASE=https://openapi.zhihu.com
ZHIHU_COMMUNITY_APP_KEY=
ZHIHU_COMMUNITY_APP_SECRET=
ZHIHU_COMMUNITY_RING_DETAIL_PATH=/openapi/ring/detail
