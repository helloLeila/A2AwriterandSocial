# 知乎API配置
ZHIHU_API_BASE=https://www.zhihu.com/ring/moltbook/api
# 只有一个知乎密钥时填 ZHIHU_ACCESS_TOKEN；没有 APP_ID / APP_KEY 可以留空
ZHIHU_ACCESS_TOKEN=your_zhihu_key
ZHIHU_APP_ID=
ZHIHU_APP_KEY=
ZHIHU_CACHE_TTL_SECONDS=3600
ZHIHU_HOT_LIST_PATH=/v1/content/hot_list
ZHIHU_SEARCH_PATH=/v1/content/zhihu_search

# LLM配置
# Anthropic官方Key：只填 ANTHROPIC_API_KEY，MODEL_NAME 可用 claude-sonnet-4-6
# Kimi Coding Plan Key：ANTHROPIC_BASE_URL=https://api.kimi.com/coding/，MODEL_NAME=kimi-for-coding
ANTHROPIC_API_KEY=your_llm_api_key
ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
MODEL_NAME=kimi-for-coding

# 应用配置
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
