# 知乎内容数据 API 配置
ZHIHU_API_BASE=https://www.zhihu.com/ring/moltbook/api
# 内容数据 API 如果只给了一个密钥，填这里；这不是 OAuth 登录回调返回的 access_token
ZHIHU_ACCESS_TOKEN=your_zhihu_key
ZHIHU_APP_ID=
ZHIHU_APP_KEY=
ZHIHU_CACHE_TTL_SECONDS=3600
ZHIHU_HOT_LIST_PATH=/v1/content/hot_list
ZHIHU_SEARCH_PATH=/v1/content/zhihu_search

# 知乎 OAuth 登录 API 配置（Base URL: https://openapi.zhihu.com）
ZHIHU_OAUTH_BASE=https://openapi.zhihu.com
# OAuth 只手填 app_id/app_key；access_token 由 /callback 用 code 换取并存在服务端 session，不写入 .env
ZHIHU_OAUTH_APP_ID=your_oauth_app_id
ZHIHU_OAUTH_APP_KEY=your_oauth_app_key
ZHIHU_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/zhihu/callback
ZHIHU_OAUTH_SUCCESS_REDIRECT=/
ZHIHU_OAUTH_AUTHORIZE_PATH=/authorize
ZHIHU_OAUTH_TOKEN_PATH=/access_token
ZHIHU_OAUTH_USERINFO_PATH=/oauth_info
ZHIHU_OAUTH_FOLLOWING_PATH=/following
ZHIHU_OAUTH_FOLLOWERS_PATH=/followers
ZHIHU_OAUTH_MUTUALS_PATH=/mutuals
ZHIHU_OAUTH_FEED_PATH=/feed

# 知乎社区 API 配置（AK/SK HMAC 签名；与 OAuth 不冲突）
ZHIHU_COMMUNITY_BASE=https://openapi.zhihu.com
# app_key 是知乎个人主页 people/ 后面的用户 token
ZHIHU_COMMUNITY_APP_KEY=your_people_token
# app_secret 是黑客松/社区 API 提供的 key
ZHIHU_COMMUNITY_APP_SECRET=your_community_secret
ZHIHU_COMMUNITY_RING_DETAIL_PATH=/openapi/ring/detail

# LLM配置
# Anthropic官方Key：只填 ANTHROPIC_API_KEY，MODEL_NAME 可用 claude-sonnet-4-6
# Kimi Coding Plan Key：ANTHROPIC_BASE_URL=https://api.kimi.com/coding/，MODEL_NAME=kimi-for-coding
ANTHROPIC_API_KEY=your_llm_api_key
ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
MODEL_NAME=kimi-for-coding

# 应用配置
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
